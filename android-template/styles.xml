<?xml version="1.0" encoding="utf-8"?>
<!-- Theme for ClawDroid Android app -->
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">#6366f1</item>
        <item name="colorPrimaryDark">#4f46e5</item>
        <item name="colorAccent">#a78bfa</item>
        <item name="android:windowBackground">#0a0a0f</item>
        <item name="android:statusBarColor">#0a0a0f</item>
        <item name="android:navigationBarColor">#0a0a0f</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Splash screen theme -->
    <style name="AppTheme.Splash" parent="AppTheme.NoActionBar">
        <item name="android:windowBackground">@drawable/splash</item>
    </style>
</resources>
